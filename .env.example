# ─────────────────────────────────────────────────────────────────
# SolarAdvisor v5.2 — 환경변수 템플릿
# 이 파일을 복사하여 .env.local 로 저장하고 각 항목의 실제 값을 채우세요.
#   PowerShell:  Copy-Item .env.example .env.local
#   Bash:        cp .env.example .env.local
# ─────────────────────────────────────────────────────────────────


# ── 로그인 인증 (필수) ────────────────────────────────────────────
# 형식: AUTH_HASH_<아이디>=<sha256(비밀번호)>
# 평문 비밀번호 절대 기입 금지. 해시 생성 예 (PowerShell):
#   "yourpassword" | %{ [BitConverter]::ToString(
#     [System.Security.Cryptography.SHA256]::Create().ComputeHash(
#       [Text.Encoding]::UTF8.GetBytes($_))).Replace("-","").ToLower() }
AUTH_HASH_yourid=your_sha256_hash_here


# ── VWorld API (필수) ─────────────────────────────────────────────
# 발급: https://www.vworld.kr/dev/v4api.do
# - 인증키 신청 → 사이트 등록 (개발: localhost:3000, 프로덕션: 도메인)
# - 같은 키 값을 두 변수에 모두 설정해야 함 (서버용 + 브라우저용)

# 서버사이드 — /api/geocode, /api/vworld 가 사용
VWORLD_API_KEY=your_vworld_key_here

# 브라우저 직접 호출용 — WMS 지적도 타일, DEM 경사도 측정
# NEXT_PUBLIC_ 접두어 → 클라이언트 번들에 포함됨 (의도적)
NEXT_PUBLIC_VWORLD_API_KEY=your_vworld_key_here


# ── 법제처 조례 API (선택) ────────────────────────────────────────
# 발급: https://open.law.go.kr → 마이페이지 → OC 발급
# 미설정 시 조례 비교 탭의 외부 검색 기능만 비활성화
LAW_API_KEY=your_law_oc_here


# ── 한국에너지기술연구원 KIER API (선택) ──────────────────────────
# 발급: https://www.data.go.kr → "한국에너지기술연구원_태양광 발전량 예측" 검색 → 활용 신청
# 동일 키로 3개 서비스 사용: SolarPvService, SolarGhiService, SrQtyService
# 미설정 시 위도 기반 추정값(3.5h/일)으로 폴백
KIER_API_KEY=your_kier_servicekey_here


# ── 한국전력거래소 SMP API (선택) ─────────────────────────────────
# 발급: https://www.data.go.kr → "한국전력거래소_계통한계가격및수요예측(B552115)" 신청
# 미설정 시 기본 SMP=110원/kWh 사용
KPX_SMP_API_KEY=your_kpx_servicekey_here


# ── Vercel KV / Upstash Redis (선택) ──────────────────────────────
# 발급: https://vercel.com/dashboard → Storage → Create Database → KV
# 미설정 시 조례 데이터는 lib/staticData.ts 정적 값만 사용 (override 비활성화)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_REDIS_URL=


# ─────────────────────────────────────────────────────────────────
# [DEPRECATED 2026-04] Kakao / Naver / Nominatim 지오코딩
# VWorld 단일 체계로 통합되어 더 이상 코드에서 참조하지 않음.
# 신규 환경에서는 추가하지 마세요.
# ─────────────────────────────────────────────────────────────────
